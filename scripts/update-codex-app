set -euo pipefail

repo="${CODEX_APP_REPO:-am-will/codex-app}"
package_file="${1:-pkgs/codex-app/package.nix}"

release_json="$(mktemp)"
trap 'rm -f "$release_json"' EXIT

curl -fsSL \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  "https://api.github.com/repos/${repo}/releases/latest" \
  -o "$release_json"

tag="$(jq -r '.tag_name' "$release_json")"
version="${tag#v}"
asset_name="codex-app-linux-x64-v${version}.AppImage"

url="$(jq -r --arg name "$asset_name" '.assets[] | select(.name == $name) | .browser_download_url' "$release_json")"
digest="$(jq -r --arg name "$asset_name" '.assets[] | select(.name == $name) | .digest' "$release_json")"

if [ -z "$url" ] || [ "$url" = "null" ]; then
  echo "Could not find release asset: $asset_name" >&2
  exit 1
fi

if [[ "$digest" != sha256:* ]]; then
  echo "Release asset has no sha256 digest: $asset_name" >&2
  exit 1
fi

hash="$(nix hash convert --to sri --hash-algo sha256 "${digest#sha256:}")"

VERSION="$version" URL="$url" HASH="$hash" perl -0pi -e '
  s/version = "[^"]+";/version = "$ENV{VERSION}";/;
  s#url = "[^"]+";#url = "$ENV{URL}";#;
  s/hash = "[^"]+";/hash = "$ENV{HASH}";/;
' "$package_file"

echo "Updated $package_file to v${version}"
